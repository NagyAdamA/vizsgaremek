# The domain name for your application (without http:// or https://)
DOMAIN=yourdomain.com

# A long, random string used by the backend to sign JWT tokens
# You can generate one with: openssl rand -base64 32
JWT_SECRET=replace_this_with_a_long_secure_random_string

# Database configuration
DB_NAME=users
DB_USER=root
# Provide strong passwords here for production
DB_ROOT_PASSWORD=replace_with_secure_root_password
DB_PASSWORD=replace_with_secure_app_password
